# Copy this file to .env and fill in your values.
# The app reads from environment variables — never hardcode secrets.

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── YouTube OAuth2 ────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 credentials (Desktop App type)
# 4. Download the JSON and place it as client_secrets.json in project root
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# ── Optional: custom playlist ID ─────────────────────────────────────────────
# Default "WL" = Watch Later / Saved videos
# To find your playlist ID: YouTube → Library → (any playlist) → URL shows ?list=PLxxxxxxx
SAVED_PLAYLIST_ID=WL

# ── Upload privacy ────────────────────────────────────────────────────────────
# Start with "private" so you can review before publishing
# Options: private | unlisted | public
UPLOAD_PRIVACY=private
